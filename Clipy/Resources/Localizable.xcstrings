    "Allow Board-Man in System Settings Privacy & Security Accessibility and Input Monitoring. Remove old Board-Man or Board-ManPasteCount entries if they remain.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow Board-Man in System Settings > Privacy & Security > Accessibility and Input Monitoring. Remove old Board-Man or Board-ManPasteCount entries if they remain."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow Board-Man in System Settings > Privacy & Security > Accessibility and Input Monitoring. Remove old Board-Man or Board-ManPasteCount entries if they remain."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow Board-Man in System Settings > Privacy & Security > Accessibility and Input Monitoring. Remove old Board-Man or Board-ManPasteCount entries if they remain."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow Board-Man in System Settings > Privacy & Security > Accessibility and Input Monitoring. Remove old Board-Man or Board-ManPasteCount entries if they remain."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム設定 > プライバシーとセキュリティ > アクセシビリティと入力監視でBoard-Manを許可してください。ONに見えても効かない場合は、一度削除してから追加し直してください。"
          }
        }
