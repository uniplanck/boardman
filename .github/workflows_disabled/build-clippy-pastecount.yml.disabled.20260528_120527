name: Build Clipy PasteCount

on:
  push:
  workflow_dispatch:

jobs:
  build:
    name: build
    runs-on: macos-15
    timeout-minutes: 25

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Select Xcode
        run: |
          sudo xcode-select -s /Applications/Xcode_16.4.app/Contents/Developer || sudo xcode-select -s /Applications/Xcode.app/Contents/Developer
          xcodebuild -version
          swift --version

      - name: Resolve packages
        run: |
          xcodebuild \
            -resolvePackageDependencies \
            -project Board-Man.xcodeproj \
            -scheme Board-Man \
            -clonedSourcePackagesDirPath .spm-cache \
            -skipPackagePluginValidation \
            -skipMacroValidation

      - name: Build Board-Man scheme
        run: |
          set -o pipefail
          xcodebuild \
            -project Board-Man.xcodeproj \
            -scheme Board-Man \
            -configuration Release \
            -destination 'generic/platform=macOS' \
            -derivedDataPath DerivedData \
            -clonedSourcePackagesDirPath .spm-cache \
            -skipPackagePluginValidation \
            -skipMacroValidation \
            CODE_SIGNING_ALLOWED=NO \
            CODE_SIGNING_REQUIRED=NO \
            CODE_SIGN_IDENTITY="" \
            ENABLE_TESTABILITY=NO \
            COMPILER_INDEX_STORE_ENABLE=NO \
            build | tee xcodebuild.log

      - name: Package app
        run: |
          set -e
          APP="$(find DerivedData/Build/Products/Release -maxdepth 3 -name 'Board-Man.app' -type d | head -1)"
          test -n "$APP"
          mkdir -p artifact
          ditto -c -k --sequesterRsrc --keepParent "$APP" artifact/Board-Man.app.zip
          ls -lah artifact

      - name: Upload app artifact
        uses: actions/upload-artifact@v4
        with:
          name: Board-Man.app
          path: artifact/Board-Man.app.zip
          if-no-files-found: error
